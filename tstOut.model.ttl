        oops:hasNumberAffectedElements  1 .

<http://oops.linkeddata.es/data/300dfbe8-828a-4ca4-992d-d43fb10fa105>
        a                               oops:pitfall;
        oops:hasCode                    "P36 - URI contains file extension";
        oops:hasDescription             "This pitfall occurs if file extensions such as \".owl\", \".rdf\", \".ttl\", \".n3\" and \".rdfxml\" are included in an ontology URI. This pitfall is related with the recommendations provided in [9].";
        oops:hasImportanceLevel         "MINOR";
        oops:hasName                    "URI contains file extension";
        oops:hasNumberAffectedElements  1 .

